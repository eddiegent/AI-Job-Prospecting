{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "candidate_name": {"type": "string"},
    "title": {"type": "string"},
    "contact_line": {"type": "string"},
    "tagline": {"type": "string"},
    "summary_paragraphs": {"type": "array", "items": {"type": "string"}},
    "skills_sections": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "heading": {"type": "string"},
          "items": {"type": "array", "items": {"type": "string"}}
        },
        "required": ["heading", "items"]
      }
    },
    "experience": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "role_line": {
            "type": "string",
            "description": "Role/job title only, e.g. 'IT Project Manager'. Rendered bold on its own line."
          },
          "metadata_line": {
            "type": "string",
            "description": "Pipe-separated 'Company | Location | Month YYYY – Month YYYY'. For the consolidated Earlier-experience entry, drop the dates and keep only pipe-separated company names (kept dateless on purpose)."
          },
          "bullets": {"type": "array", "items": {"type": "string"}}
        },
        "required": ["role_line", "metadata_line", "bullets"]
      }
    },
    "education": {"type": "array", "items": {"type": "string"}},
    "languages": {"type": "array", "items": {"type": "string"}}
  },
  "required": ["candidate_name", "title", "experience"]
}
