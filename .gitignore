.claude/scheduled_tasks.lock

# Python
__pycache__/
*.pyc

# OS
Thumbs.db
Desktop.ini
.DS_Store

# Editor
.vscode/
.idea/

# Personal data (do not publish)
resources/MASTER_CV.docx
resources/*.docx
resources/cv-text/

# Skill cache (auto-generated)
resources/.cv_hash
resources/cv_fact_base.json

# User-owned customization layer (Phase 1 — per-user, never committed)
resources/cv_addendum.md
resources/old_cv_addendum.md
resources/user_prefs.yaml

# First-run seeds copied by scripts/init.py into the user data dir (Phase 4)
resources/cv_addendum.template.md
resources/user_prefs.template.yaml

# Job history database
resources/job_history.db

# Example files with personal data
.claude/skills/job-application-tailor/scripts/example_*.json
.claude/skills/job-application-tailor/scripts/example_*.md

# Generated outputs
output/

# Skill creator workspace
job-application-tailor-workspace/

# Stray config
resources/.claude/

# Pre-plugin-migration backups (created by scripts/backup_user_data.py)
backups/

# Auto DB snapshots taken before mutating commands (cli.py; contain real
# pipeline data, live next to the git-ignored job_history.db)
db-backups/

# Packaged plugin bundles (created by scripts/package.py)
dist/

# Personal application-tracker exports — embed real pipeline data (company
# names + statuses); the repo is public, so keep these out like the DB.
Job Application Tracker*.html
